# Job Autopilot Server Configuration
PORT=3001

# Gemini API Key (Obtén una GRATIS en Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# SMTP Email Configuration (Nodemailer para auto-envío de candidaturas)
# Si usas Gmail, obtén una "Contraseña de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion_aqui

# Notificaciones Push a Móvil / Slack (Opcional)
PUSHOVER_USER_KEY=
PUSHOVER_TOKEN=
SLACK_WEBHOOK_URL=

# Google Sheets Backup Integración (Opcional)
GOOGLE_SHEET_ID=

# ─── PORTALES EUROPEOS / ESPAÑOLES (Keys Opcionales) ──────────────────────────
# Jooble API — Excelente cobertura en España (Gratis en: https://jooble.org/api/about)
JOOBLE_API_KEY=

# Adzuna API — Agregador global y europeo (Gratis en: https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
